# TestPlatform .htaccess
# Размести в C:\xampp\htdocs\test-platform\

Options -Indexes

# Защита конфига
<Files "config.php">
    Order Allow,Deny
    Deny from all
</Files>

# Не открывать php файлы в /src напрямую
<FilesMatch "^.*\.php$">
    <If "%{REQUEST_URI} =~ m|/src/|">
        Order Allow,Deny
        Deny from all
    </If>
</FilesMatch>

# Кэш статики
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css "access plus 1 week"
    ExpiresByType application/javascript "access plus 1 week"
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType image/jpeg "access plus 1 month"
</IfModule>

# GZIP
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json
</IfModule>

# PHP настройки
php_value upload_max_filesize 10M
php_value post_max_size 12M
php_value max_execution_time 60

# Запрет прямого доступа к sensitive файлам
<FilesMatch "\.(env|log|sql|md|txt|gitignore)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>
